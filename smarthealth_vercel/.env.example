# ═══════════════════════════════════════════════
#  SmartHealth AI — Variables de entorno
#  Copia como .env y completa los valores
# ═══════════════════════════════════════════════

PORT=3131

# Opción A: URL completa (Vercel + Neon/Supabase/Railway)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Opción B: Variables individuales (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smarthealth
DB_USER=smarthealth_user
DB_PASSWORD=tu_password_aqui

# JWT — Cambia esto por una cadena larga y aleatoria
JWT_SECRET=cambia_esto_por_algo_seguro_y_largo

# Claude AI — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
