# ═══════════════════════════════════════════════
#  SmartHealth AI — Variables de entorno
#  Copia como .env y completa los valores
# ═══════════════════════════════════════════════

PORT=3131

# ── BASE DE DATOS ─────────────────────────────
#
# SUPABASE (recomendado para Vercel):
#   1. Ir a supabase.com → tu proyecto → Settings → Database
#   2. En "Connection string" seleccionar "Transaction pooler" (puerto 6543)
#   3. Copiar la URL y reemplazar [YOUR-PASSWORD] con tu contraseña
#
#   Formato: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# NEON (alternativa gratuita):
#   Formato: postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require
#
# IMPORTANTE: En Vercel agrega esta variable en:
#   Project Settings → Environment Variables → DATABASE_URL
#
DATABASE_URL=postgresql://postgres.[tu-ref]:[tu-password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Opción local (cuando NO se define DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smarthealth
DB_USER=smarthealth_user
DB_PASSWORD=tu_password_aqui

# ── JWT ───────────────────────────────────────
# Genera una cadena aleatoria segura, por ejemplo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_algo_seguro_y_largo_minimo_32_chars

# ── CLAUDE AI ────────────────────────────────
# Obtén tu API Key en: https://console.anthropic.com/settings/keys
# Si se deja vacío, el sistema usa respuestas simuladas (modo demo).
ANTHROPIC_API_KEY=
